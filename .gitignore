# =============================================================================
# landuse_ref — .gitignore
#
# Input data files (AOI GeoJSON, building footprints, CCCM masterlists, OSM
# PBF extracts) and all pipeline outputs (GeoPackages, CSVs) are excluded from
# version control. These files must be supplied or generated locally. Only the
# empty directory skeleton is committed via .gitkeep files.
# =============================================================================

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/

# ---------------------------------------------------------------------------
# Python bytecode and cache
# ---------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo

# ---------------------------------------------------------------------------
# Input data — user-supplied and downloaded files
# ---------------------------------------------------------------------------
data/input/
!data/input/.gitkeep

# ---------------------------------------------------------------------------
# Pipeline outputs — large binary and regenerated files
# ---------------------------------------------------------------------------
data/*.gpkg
data/*_scratch.gpkg
data/*.csv
data/scratch/
!data/.gitkeep

# ---------------------------------------------------------------------------
# Temporary and diagnostic scripts
# ---------------------------------------------------------------------------
debug_overture.py

# ---------------------------------------------------------------------------
# Environment and secrets
# ---------------------------------------------------------------------------
.env

# ---------------------------------------------------------------------------
# Python packaging artefacts
# ---------------------------------------------------------------------------
*.egg-info/
dist/
build/

# ---------------------------------------------------------------------------
# OS artefacts
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
